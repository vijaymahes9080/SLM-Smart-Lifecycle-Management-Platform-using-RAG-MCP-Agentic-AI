# SLM (Smart Lifecycle Management) Platform Configurations

# Default FastAPI port and hostname
PORT=8000
HOST=0.0.0.0

# Database Settings (Defaults to local SQLite slm_platform.db)
DATABASE_URL=sqlite:///./slm_platform.db

# Vector Search and Agents Models (Default model: gemini-2.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here
DEFAULT_MODEL=gemini-2.5-flash

# Next.js configurations
NEXT_PUBLIC_API_URL=http://localhost:8000
